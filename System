from fastapi import FastAPI
from pydantic import BaseModel
from cryptography.fernet import Fernet
from datetime import datetime, timedelta
from typing import List

app = FastAPI(
    title="Operação Carga Rápida",
    version="1.0"
)

CHAVE = Fernet.generate_key()

fernet = Fernet(CHAVE)

def criptografar(texto):
    return fernet.encrypt(
        texto.encode()
    ).decode()

def descriptografar(texto):
    return fernet.decrypt(
        texto.encode()
    ).decode()

agendamentos = []

class Agendamento(BaseModel):

    cnpj_cliente: str

    cnpj_transportadora: str

    awb: str

    placa: str

    peso_kg: float

    tipo_carga: str

    data_agendamento: datetime

CAPACIDADE_HORA = 10

def sugerir_slot():

    agora = datetime.now()

    for h in range(1, 72):

        slot = agora + timedelta(hours=h)

        quantidade = 0

        for item in agendamentos:

            horario = item["data_agendamento"]

            if (
                horario.year == slot.year
                and
                horario.month == slot.month
                and
                horario.day == slot.day
                and
                horario.hour == slot.hour
            ):
                quantidade += 1

        if quantidade < CAPACIDADE_HORA:

            return slot

    return None


def enviar_sms(numero, mensagem):

    print(
        f"SMS enviado para {numero}"
    )

    print(
        mensagem
    )

    return True

@app.get("/")

def home():

    return {

        "projeto":
        "Operação Carga Rápida",

        "status":
        "online"
    }

@app.post("/agendamento")

def criar_agendamento(
    dados: Agendamento
):

    registro = {

        "id":
        len(agendamentos) + 1,

        "cnpj_cliente":
        criptografar(
            dados.cnpj_cliente
        ),

        "cnpj_transportadora":
        criptografar(
            dados.cnpj_transportadora
        ),

        "awb":
        dados.awb,

        "placa":
        dados.placa,

        "peso_kg":
        dados.peso_kg,

        "tipo_carga":
        dados.tipo_carga,

        "data_agendamento":
        dados.data_agendamento,

        "status":
        "AGENDADO",

        "assinatura_realizada":
        False
    }

    agendamentos.append(
        registro
    )

    enviar_sms(
        "11999999999",
        "Seu agendamento foi confirmado."
    )

    return {

        "mensagem":
        "Agendamento realizado",

        "dados":
        registro
    }


@app.get("/agendamentos")

def listar_agendamentos():

    return agendamentos

@app.get("/agendamento/{id}")

def buscar_agendamento(id: int):

    for item in agendamentos:

        if item["id"] == id:

            return item

    return {

        "erro":
        "Agendamento não encontrado"
    }


@app.put(
    "/assinatura/{id}"
)

def realizar_assinatura(
    id: int
):

    for item in agendamentos:

        if item["id"] == id:

            item[
                "assinatura_realizada"
            ] = True

            return {

                "mensagem":
                "Assinatura registrada"
            }

    return {

        "erro":
        "Agendamento não encontrado"
    }


@app.get(
    "/sugerir-slot"
)

def recomendacao():

    slot = sugerir_slot()

    return {

        "horario_sugerido":
        slot
    }


@app.get("/kpis")

def indicadores():

    total_agendamentos = len(
        agendamentos
    )

    assinaturas = sum(

        1

        for a in agendamentos

        if a[
            "assinatura_realizada"
        ]
    )

    percentual_assinaturas = 0

    if total_agendamentos > 0:

        percentual_assinaturas = (

            assinaturas
            /
            total_agendamentos

        ) * 100

    return {

        "agendamentos":
        total_agendamentos,

        "assinaturas":
        assinaturas,

        "percentual_assinaturas":
        round(
            percentual_assinaturas,
            2
        ),

        "economia_papel":
        "90%",

        "tempo_medio_atendimento":
        "25 minutos"
    }

